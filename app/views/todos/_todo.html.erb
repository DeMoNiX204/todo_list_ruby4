<%= turbo_frame_tag dom_id(todo) do %>                                                                                                                                                             
      <div class="p-4 flex items-center justify-between hover:bg-gray-50 dark:hover:bg-gray-800 transition duration-150">                                                                              
        <div class="flex items-center gap-3">                                                                                                                                                          
          <!-- คำนวณสี Badge และข้อความตามสถานะ -->                                                                                                                                                       
          <% badge_color = case todo.status                                                                                                                                                            
                           when "completed" then "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400"                                                                                
                           when "in_progress" then "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400"                                                                                  
                           else "bg-gray-100 text-gray-850 dark:bg-gray-800 dark:text-gray-400"                                                                                                        
                           end %>                                                                                                                                                                      
          <% status_label = case todo.status                                                                                                                                                           
                            when "completed" then "เสร็จสิ้น"                                                                                                                                             
                            when "in_progress" then "กำลังทำ"                                                                                                                                             
                            else "รอดำเนินการ"                                                                                                                                                           
                            end %>                                                                                                                                                                     
                                                                                                                                                                                                       
          <% if todo.overdue? %>                                                                                                                                                                       
            <% badge_color = "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400" %>                                                                                                         
            <% status_label = "เลยกำหนด" %>                                                                                                                                                             
          <% end %>                                                                                                                                                                                    
                                                                                                                                                                                                       
          <span class="px-2.5 py-1 text-xs font-semibold rounded-full <%= badge_color %>">                                                                                                             
            <%= status_label %>                                                                                                                                                                        
          </span>                                                                                                                                                                                      
                                                                                                                                                                                                       
          <div>                                                                                                                                                                                        
            <h3 class="text-sm font-semibold text-gray-900 dark:text-white <%= 'line-through text-gray-400' if todo.completed? %>">                                                                    
              <%= todo.title %>                                                                                                                                                                        
            </h3>                                                                                                                                                                                      
            <% if todo.description.present? %>                                                                                                                                                         
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5"><%= todo.description %></p>                                                                                                   
            <% end %>                                                                                                                                                                                  
            <% if todo.due_date.present? %>                                                                                                                                                            
              <span class="text-[10px] text-gray-400 flex items-center gap-1 mt-1">                                                                                                                    
                📅 กำหนดส่ง: <%= todo.due_date.strftime("%d/%m/%Y %H:%M") %>                                                                                                                             
              </span>                                                                                                                                                                                  
            <% end %>                                                                                                                                                                                  
          </div>                                                                                                                                                                                       
        </div>                                                                                                                                                                                         
                                                                                                                                                                                                       
        <!-- ปุ่ม Action -->                                                                                                                                                                             
        <div class="flex items-center gap-2">                                                                                                                                                          
          <%= link_to "แก้ไข", edit_todo_path(todo), class: "text-xs text-blue-600 hover:text-blue-800 font-medium px-2 py-1 rounded cursor-pointer", data: { turbo: false } %>                         
          <%= button_to "ลบ", todo_path(todo), method: :delete, data: { confirm: "ต้องการลบงานนี้จริงไหม?" }, form: { data: { turbo_frame: "_top" } }, class: "text-xs text-red-600 hover:text-red-800 font-     
  medium px-2 py-1 rounded cursor-pointer" %>                                                                                                                                                                                                   
        </div>                                                                                                                                                                                         
      </div>                                                                                                                                                                                           
    <% end %>