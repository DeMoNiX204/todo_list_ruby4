<div class="max-w-axl mx-auto px-4 py-8">
    <div class="flex justify-between item-center mb-8">
        <h1 class="text-3xl text-gray-900 dark:text-whilte"> Todo List</h1>
        <%= link_to "เพิ่มงานใหม่", new_todo_path, class: "bg-blue-600 hover:bg-blue-700 text-white font-medium px-4 py-2 rounded-lg transition duration-150 ease-in-out shadow cursor-pointer" %>
    </div>
    <%= form_with url: todos_path, method: :get, data: { turbo_frame: "todos_list", turbo_action: "advance" }, class: "mb-6 flex flex-col md:flex-row gap-4" do |f| %> 
        <div class="flex-grow">                                                                                                                                                                        
            <%= f.text_field :query, value: params[:query], placeholder: "ค้นหาชื่องาน...", class: "w-full px-4 py-2 border rounded-lg dark:bg-gray-800 dark:border-gray-700 focus:outline-none focus:ring-2
    focus:ring-blue-500" %> 
        </div>
        <div class="w-full md:w-48">                                                                                                                                                                   
            <%= f.select :status, [["ทั้งหมด", ""], ["Pending", "pending"], ["กำลังทำ", "in_progress"], ["เสร็จสิ้น", "completed"], ["เลยกำหนดส่ง", "overdue"]], { selected: params[:status] }, { class: "w-full   
    px-4 py-2 border rounded-lg dark:bg-gray-800 dark:border-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500" } %>                                                                          
        </div>  
        <%= f.submit "ค้นหา", class: "bg-gray-100 hover:bg-gray-200 text-gray-800 dark:bg-gray-700 dark:hover:bg-gray-600 dark:text-white px-4 py-2 rounded-lg font-medium cursor-pointer" %>           
    <% end %>
    <%= turbo_frame_tag "todos_list" do %>                                                                                                                                                           
        <div id="todos_container" class="bg-white dark:bg-gray-900 rounded-xl shadow-md border dark:border-gray-800 divide-y dark:divide-gray-800">                                                                         
          <% if @todos.any? %>                                                                                                                                                                         
            <%= render @todos %>                                                                                                                                                                       
          <% else %>                                                                                                                                                                                   
            <div id="no_todos_placeholder" class="p-8 text-center text-gray-500">                                                                                                                                                
              ไม่พบรายการ Todo                                                                                                                                                                       
            </div>                                                                                                                                                                                     
          <% end %>                                                                                                                                                                                    
        </div>                                                                                                                                                                                         
      <% end %>                                                                                                                                                                                        
    </div>                                       
</div>