<%= form_with model: todo, class: "space-y-4" do |f| %>                                                                                                                                            
    <% if todo.errors.any? %>                                                                                                                                                                        
        <div class="p-4 mb-4 text-sm text-red-850 rounded-lg bg-red-50 dark:bg-gray-800 dark:text-red-400">                                                                                            
          <h4 class="font-bold"><%= pluralize(todo.errors.count, "error") %> ทำให้ไม่สามารถบันทึกได้:</h4>                                                                                                   
          <ul class="list-disc pl-5 mt-1">                                                                                                                                                             
            <% todo.errors.full_messages.each do |msg| %>                                                                                                                                              
              <li><%= msg %></li>                                                                                                                                                                      
            <% end %>                                                                                                                                                                                  
          </ul>                                                                                                                                                                                        
        </div>                                                                                                                                                                                         
    <% end %>                                                                                                                                                                                        
                                                                                                                                                                                                       
    <div>                                                                                                                                                                                            
        <%= f.label :title, "หัวข้องาน", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>                                                                                          
        <%= f.text_field :title, class: "mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm dark:bg-gray-800 dark:border- 
  gray-700" %>                                                                                                                                                                                         
    </div>                                                                                                                                                                                           
                                                                                                                                                                                                       
    <div>                                                                                                                                                                                            
        <%= f.label :description, "รายละเอียด", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>                                                                                  
        <%= f.text_area :description, rows: 3, class: "mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm dark:bg-gray-800
  dark:border-gray-700" %>                                                                                                                                                                             
    </div>                                                                                                                                                                                           
                                                                                                                                                                                                       
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">                                                                                                                                              
        <div>                                                                                                                                                                                          
          <%= f.label :status, "สถานะ", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>                                                                                         
          <%= f.select :status, [["รอดำเนินการ", "pending"], ["กำลังทำ", "in_progress"], ["เสร็จสิ้น", "completed"]], {}, class: "mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none   
  focus:ring-blue-500 focus:border-blue-500 sm:text-sm dark:bg-gray-800 dark:border-gray-700" %>                                                                                                       
        </div>                                                                                                                                                                                         
                                                                                                                                                                                                       
        <div>                                                                                                                                                                                          
          <%= f.label :due_date, "วันกำหนดส่ง", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>                                                                                    
          <%= f.datetime_field :due_date, class: "mt-1 block w-full px-3 py-2 border rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm dark:bg-gray-800     
  dark:border-gray-700" %>                                                                                                                                                                             
        </div>                                                                                                                                                                                         
    </div>                                                                                                                                                                                           
                                                                                                                                                                                                       
    <div class="flex justify-end gap-3 pt-4">                                                                                                                                                        
        <%= link_to "ยกเลิก", todos_path, class: "px-4 py-2 border rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800 cursor- 
  pointer" %>                                                                                                                                                                                          
        <%= f.submit "บันทึกข้อมูล", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white font-medium rounded-md text-sm cursor-pointer shadow" %>                                                   
    </div>                                                                                                                                                                                           
<% end %> 